1. צד שרת (Cloud Function)
ניצור פונקציה מסוג Callable ב-Firebase שתבצע שלוש פעולות: בדיקה שהסוכן לא קיים, יצירת ה-Stub, ושליחת המייל (באמצעות nodemailer או שירות כמו Resend/SendGrid שמוגדר אצלך).

TypeScript
// back/functions/src/team/sendAgentInvite.ts
import * as functions from 'firebase-functions';
import * as admin from 'firebase-admin';
import * as nodemailer from 'nodemailer'; // או כל שירות דיוור אחר שאתה עובד איתו
import { v4 as uuidv4 } from 'uuid';

export const sendAgentInvite = functions.https.onCall(async (data, context) => {
  // 1. אימות הרשאות (רק מנהל יכול להזמין)
  if (!context.auth || context.auth.token.role !== 'admin') {
    throw new functions.https.HttpsError('permission-denied', 'Only admins can invite agents.');
  }

  const { email } = data;
  const agencyId = context.auth.token.agencyId;
  const db = admin.firestore();

  // 2. בדיקה אם המשתמש כבר קיים ופעיל
  const existingUsers = await db.collection('users').where('email', '==', email).get();
  if (!existingUsers.empty) {
    const user = existingUsers.docs[0].data();
    if (user.uid) {
      throw new functions.https.HttpsError('already-exists', 'User is already registered.');
    }
  }

  // 3. יצירת הטוקן ומשתמש ה-Stub
  const inviteToken = uuidv4();
  await db.collection('users').doc(email).set({
    email,
    agencyId,
    role: 'agent',
    inviteToken,
    createdAt: admin.firestore.FieldValue.serverTimestamp(),
    uid: null // יתמלא כשהוא יתחבר עם גוגל
  }, { merge: true });

  // 4. שליחת המייל
  const inviteLink = `https://homer.management/join?token=${inviteToken}`;
  
  const transporter = nodemailer.createTransport({
    // הגדרות ה-SMTP שלך (להביא מ-functions.config או Secret Manager)
  });

  const mailOptions = {
    from: '"hOMER Management" <noreply@homer.management>',
    to: email,
    subject: 'הזמנה להצטרף למשרד ב-hOMER',
    html: `
      <div dir="rtl" style="font-family: Arial; text-align: right;">
        <h2>הוזמנת להצטרף לסוכנות הנדל"ן שלך!</h2>
        <p>מנהל המשרד הזמין אותך להתחבר למערכת hOMER.</p>
        <a href="${inviteLink}" style="background: #2563eb; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; display: inline-block;">
          לחץ כאן להרשמה (דרך Google)
        </a>
      </div>
    `
  };

  await transporter.sendMail(mailOptions);

  return { success: true, message: 'Invite sent successfully' };
});
2. ממשק המשתמש (React / Tailwind)
בתוך מסך הגדרות הצוות (למשל Settings.tsx או TeamManagement.tsx), נוסיף רכיב קטן של Input וכפתור.

TypeScript
// frontend/src/components/Team/InviteAgentBlock.tsx
import React, { useState } from 'react';
import { Send, Loader2 } from 'lucide-react';
import { httpsCallable } from 'firebase/functions';
import { functions } from '../../firebase'; // נתיב לקובץ ה-init שלך
import toast from 'react-hot-toast'; // ספריה להודעות קופצות

export const InviteAgentBlock = () => {
  const [email, setEmail] = useState('');
  const [isLoading, setIsLoading] = useState(false);

  const handleSendInvite = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!email) return;

    setIsLoading(true);
    try {
      const sendInvite = httpsCallable(functions, 'sendAgentInvite');
      await sendInvite({ email });
      
      toast.success('ההזמנה נשלחה בהצלחה למייל: ' + email);
      setEmail('');
    } catch (error: any) {
      if (error.code === 'already-exists') {
        toast.error('המשתמש הזה כבר רשום במערכת.');
      } else {
        toast.error('שגיאה בשליחת ההזמנה. נסה שוב.');
      }
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className="bg-white p-6 rounded-xl border border-slate-200 shadow-sm mt-6">
      <h3 className="text-lg font-bold text-slate-800 mb-2">הזמנת סוכן חדש</h3>
      <p className="text-sm text-slate-500 mb-4">
        הזן את כתובת המייל של הסוכן והוא יקבל קישור הצטרפות ישירות למשרד.
      </p>
      
      <form onSubmit={handleSendInvite} className="flex items-center gap-3">
        <input
          type="email"
          placeholder="agent@example.com"
          required
          value={email}
          onChange={(e) => setEmail(e.target.value)}
          className="flex-1 px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition-all text-left"
          dir="ltr"
        />
        <button
          type="submit"
          disabled={isLoading}
          className="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium transition-colors disabled:opacity-70"
        >
          {isLoading ? <Loader2 className="w-5 h-5 animate-spin" /> : <Send className="w-5 h-5" />}
          <span>שלח הזמנה</span>
        </button>
      </form>
    </div>
  );
};
3. עדכון הכללים ואבטחה
Firebase Rules: אין צורך לעדכן Rules מיוחדים כי הפעולה של יצירת ה-Stub מתבצעת ב-Backend באמצעות ה-admin SDK (שעוקף את חוקי ה-Client). אימות ההרשאה (Admin) מתבצע בתוך הפונקציה עצמה.

טיפול במייל: הקפד לשמור את פרטי ה-SMTP (סיסמה/API Key) ב-Google Cloud Secret Manager ולא כטקסט חשוף בקוד, כפי שציינת במסמך ה-AI_ARCHITECTURE.md.