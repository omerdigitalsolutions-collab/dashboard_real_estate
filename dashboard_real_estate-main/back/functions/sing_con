כדי שהמערכת תעבוד בצורה מושלמת בסגנון "DocuSign", ריכזתי לך כאן את כל חלקי הקוד המרכזיים – מה-Backend ועד ה-Front.

המערכת בנויה על: React (Frontend), Firebase Functions (Backend), וספריית pdf-lib לעריכת מסמכים.

1.
ה-Cloud Function המלאה (signDeal)
כך זה צריך להיראות בתוך קובץ ה-index.js או ה-functions.js שלך בתיקיית ה-Functions:

JavaScript
const { onCall, HttpsError } = require("firebase-functions/v2/https");
const admin = require("firebase-admin");
const { PDFDocument } = require("pdf-lib");
const fetch = require("node-fetch");

exports.signDeal = onCall(async (request) => {
  // 1. חילוץ הנתונים שהגיעו מה-Frontend
  const { agencyId, dealId, signature, fields, uiContainer } = request.data;
  const userId = request.auth?.uid;

  // בדיקות תקינות בסיסיות
  if (!request.auth) {
    throw new HttpsError("unauthenticated", "רק משתמשים מחוברים יכולים לחתום.");
  }
  if (!uiContainer || !uiContainer.width || !uiContainer.height) {
    throw new HttpsError("invalid-argument", "חסרות מידות המסך (uiContainer) הנדרשות לחישוב מיקום החתימה.");
  }

  try {
    const db = admin.firestore();
    const dealRef = db.collection("agencies").doc(agencyId).collection("deals").doc(dealId);
    const dealDoc = await dealRef.get();
    
    if (!dealDoc.exists) {
        throw new HttpsError("not-found", "העסקה לא נמצאה.");
    }
    
    const dealData = dealDoc.data();

    // 2. הורדת ה-PDF המקורי מה-Storage
    const pdfBytes = await fetch(dealData.contract.pdfUrl).then(res => res.arrayBuffer());
    const pdfDoc = await PDFDocument.load(pdfBytes);
    
    // 3. הכנת תמונת החתימה (המרת ה-Base64 שחזר מ-SignatureCanvas)
    const base64Data = signature.replace(/^data:image\/\w+;base64,/, "");
    const signatureImageBytes = Buffer.from(base64Data, "base64");
    const signatureImage = await pdfDoc.embedPng(signatureImageBytes);
    
    // 4. צריבת החתימה בעזרת החישוב המתמטי
    const pages = pdfDoc.getPages();
    
    // גודל החתימה הרצוי בפיקסלים על המסך (כפי שמוגדר ב-UI)
    const uiSignatureWidth = 120;
    const uiSignatureHeight = 50;

    fields.forEach(field => {
      if (field.type === 'signature') {
        // מציאת העמוד הרלוונטי (מערך מתחיל מ-0, דפים מ-1)
        const pageIndex = (field.page || 1) - 1;
        if (pageIndex < 0 || pageIndex >= pages.length) return;
        
        const page = pages[pageIndex];
        const { width: pdfWidth, height: pdfHeight } = page.getSize();

        // אלגוריתם יחס ההמרה (Scale)
        const scaleX = pdfWidth / uiContainer.width;
        const scaleY = pdfHeight / uiContainer.height;

        const finalSigWidth = uiSignatureWidth * scaleX;
        const finalSigHeight = uiSignatureHeight * scaleY;

        // המרת קואורדינטות והיפוך ציר ה-Y
        const finalX = field.x * scaleX;
        const finalY = pdfHeight - (field.y * scaleY) - finalSigHeight;

        // "ציור" התמונה על גבי ה-PDF האמיתי
        page.drawImage(signatureImage, {
          x: finalX,
          y: finalY,
          width: finalSigWidth,
          height: finalSigHeight,
        });
      }
    });

    // 5. שמירת ה-PDF החתום בחזרה ל-Firebase Storage
    const modifiedPdfBytes = await pdfDoc.save();
    const filename = `agencies/${agencyId}/deals/${dealId}/signed_contract_${Date.now()}.pdf`;
    const bucket = admin.storage().bucket();
    const file = bucket.file(filename);
    
    await file.save(modifiedPdfBytes, { 
        contentType: "application/pdf",
        metadata: {
            metadata: {
                signedBy: userId,
                dealId: dealId
            }
        }
    });
    
    // יצירת URL לגישה לקובץ החתום
    const signedUrl = `https://storage.googleapis.com/${bucket.name}/${filename}`;

    // 6. עדכון מסמך העסקה (Deal) ב-Firestore
    await dealRef.update({
      "contract.signedPdfUrl": signedUrl,
      "contract.status": "signed",
      "status": "active", // העסקה הופכת לפעילה עם חתימת החוזה
      "metadata.updatedAt": admin.firestore.FieldValue.serverTimestamp(),
      "metadata.signedAt": admin.firestore.FieldValue.serverTimestamp()
    });

    return { success: true, url: signedUrl };

  } catch (error) {
    console.error("Error signing deal:", error);
    throw new HttpsError("internal", "אירעה שגיאה בעת עיבוד החתימה: " + error.message);
  }
});
