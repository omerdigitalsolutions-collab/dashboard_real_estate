2. ה-Frontend: קומפוננטת "קשקוש" (SignatureCanvas.tsx)
הרכיב שמאפשר ללקוח לחתום עם העכבר או האצבע.

TypeScript
import React, { useRef, useState } from 'react';

export function SignatureCanvas({ onSignatureChange }) {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const [isDrawing, setIsDrawing] = useState(false);

  const startDrawing = (e) => {
    const canvas = canvasRef.current;
    const ctx = canvas?.getContext('2d');
    if (!ctx) return;
    setIsDrawing(true);
    const rect = canvas.getBoundingClientRect();
    ctx.beginPath();
    ctx.moveTo(e.clientX - rect.left, e.clientY - rect.top);
  };

  const draw = (e) => {
    if (!isDrawing) return;
    const canvas = canvasRef.current;
    const ctx = canvas?.getContext('2d');
    const rect = canvas.getBoundingClientRect();
    ctx?.lineTo(e.clientX - rect.left, e.clientY - rect.top);
    ctx?.stroke();
  };

  const stopDrawing = () => {
    setIsDrawing(false);
    const dataURL = canvasRef.current?.toDataURL();
    onSignatureChange(dataURL); // שליחת ה-Base64 לאבא
  };

  return (
    <canvas 
      ref={canvasRef} 
      onMouseDown={startDrawing} 
      onMouseMove={draw} 
      onMouseUp={stopDrawing}
      className="border-2 border-dashed w-full h-40 bg-white cursor-crosshair"
    />
  );
}
3. ה-Frontend: ניהול גרסאות ושמירה (contractService.ts)
הלוגיקה ששומרת חוזה חדש או מעדכנת קיים, תוך שמירת גרסה אחת אחורה ומניעת מחיקה.

TypeScript
import { doc, updateDoc, getDoc, serverTimestamp } from 'firebase/firestore';
import { db } from '../firebaseConfig';

export const saveContractUpdate = async (agencyId, contractId, newData) => {
  const contractRef = doc(db, `agencies/${agencyId}/contracts`, contractId);
  const snap = await getDoc(contractRef);
  const currentData = snap.data();

  // מניעת עריכה אם חתום
  if (currentData?.status === 'signed') throw new Error("חוזה חתום לא ניתן לעריכה");

  // גיבוי גרסה קודמת
  const lastVersion = {
    content: currentData.content,
    fields: currentData.fields,
    updatedAt: currentData.updatedAt
  };

  return await updateDoc(contractRef, {
    ...newData,
    lastVersion, // שמירת הגרסה הישנה בתוך המסמך
    updatedAt: serverTimestamp()
  });
};
