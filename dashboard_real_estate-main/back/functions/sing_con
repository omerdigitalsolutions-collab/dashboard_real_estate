עורך החוזים (לסוכן): ממשק Drag & Drop
השתמשתי ב-react-draggable כדי לאפשר לסוכן למקם את השדות על גבי דף החוזה.    
import React, { useState, useRef } from 'react';
import Draggable from 'react-draggable';
import { Type, PenTool, Calendar, User, Save } from 'lucide-react';

// סוגי השדות שאפשר להוסיף
const FIELD_TYPES = [
  { id: 'signature', label: 'חתימה', icon: <PenTool size={16} />, color: 'bg-blue-500' },
  { id: 'agent_name', label: 'שם סוכן', icon: <User size={16} />, color: 'bg-green-500' },
  { id: 'client_name', label: 'שם לקוח', icon: <User size={16} />, color: 'bg-orange-500' },
  { id: 'date', label: 'תאריך', icon: <Calendar size={16} />, color: 'bg-purple-500' },
];

export function ContractEditor({ pdfUrl, onSave }) {
  const [fields, setFields] = useState([]);
  const containerRef = useRef(null);

  const addField = (type) => {
    const newField = {
      id: Date.now(),
      type: type.id,
      label: type.label,
      x: 50, // מיקום התחלתי
      y: 50,
      page: 1
    };
    setFields([...fields, newField]);
  };

  const handleStop = (id, data) => {
    setFields(fields.map(f => f.id === id ? { ...f, x: data.x, y: data.y } : f));
  };

  return (
    <div className="flex h-[800px] bg-gray-100 p-4 gap-4 overflow-hidden">
      {/* סרגל כלים בצד */}
      <div className="w-64 bg-white p-4 rounded-lg shadow-md flex flex-col gap-3">
        <h3 className="font-bold mb-2">גרור שדות למסמך</h3>
        {FIELD_TYPES.map(type => (
          <button
            key={type.id}
            onClick={() => addField(type)}
            className="flex items-center gap-2 p-3 border rounded-lg hover:bg-gray-50 transition"
          >
            {type.icon}
            <span>{type.label}</span>
          </button>
        ))}
        <button 
          onClick={() => onSave(fields)}
          className="mt-auto bg-black text-white p-3 rounded-lg flex items-center justify-center gap-2"
        >
          <Save size={18} /> שמור תבנית
        </button>
      </div>

      {/* אזור המסמך */}
      <div 
        ref={containerRef}
        className="flex-1 relative bg-white shadow-inner overflow-auto flex justify-center p-8"
      >
        <div className="relative border shadow-2xl bg-white w-[595px] h-[842px]"> {/* גודל A4 בפיקסלים */}
          {/* כאן תבוא התצוגה של ה-PDF המקורי */}
          <div className="absolute inset-0 flex items-center justify-center text-gray-300 pointer-events-none">
             תצוגת PDF מקורי (רקע)
          </div>

          {/* שכבת השדות הדינמיים */}
          {fields.map((field) => (
            <Draggable
              key={field.id}
              bounds="parent"
              defaultPosition={{ x: field.x, y: field.y }}
              onStop={(e, data) => handleStop(field.id, data)}
            >
              <div className={`absolute cursor-move p-2 rounded shadow-sm text-white text-xs flex items-center gap-2 ${
                FIELD_TYPES.find(t => t.id === field.type)?.color
              }`}>
                <PenTool size={12} />
                {field.label}
              </div>
            </Draggable>
          ))}
        </div>
      </div>
    </div>
  );
}


