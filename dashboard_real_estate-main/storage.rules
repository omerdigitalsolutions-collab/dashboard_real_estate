rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ══════════════════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ══════════════════════════════════════════════════════════════════════════
    match /{allPaths=**} {
      allow read, write: if false;
    }


    // ══════════════════════════════════════════════════════════════════════════
    // USER PROFILE PICTURES
    // ══════════════════════════════════════════════════════════════════════════
    match /users/{userId}/profile/{fileName} {
      // Profile photos are readable by:
      //  1. The owner themselves
      //  2. ANY authenticated user in the SAME agency (so teammates see each other's avatars)
      // Write/delete is always owner-only.
      allow read: if request.auth != null && (
        request.auth.uid == userId
        || firestore.get(/databases/(default)/documents/users/$(userId)).data.agencyId == request.auth.token.agencyId
      );

      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 5 * 1024 * 1024
                            && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null && request.auth.uid == userId;
    }


    // ══════════════════════════════════════════════════════════════════════════
    // AGENCY STORAGE
    // ✅ FIX #6: Added explicit "/" separator after {agencyId} so that nested
    //            match blocks resolve to the correct full paths in Firebase
    //            Storage (unlike Firestore, Storage path concatenation requires
    //            the leading slash on every child segment).
    // ══════════════════════════════════════════════════════════════════════════

    function isSuperAdmin() {
      return request.auth != null && (
        firestore.exists(/databases/(default)/documents/superAdmins/$(request.auth.uid))
      );
    }

    // Helper: checks if caller is an admin/owner of the given agency.
    // Falls back to Firestore if token claims are stale or not yet set.
    function isAgencyAdmin(agencyId) {
      return isSuperAdmin() || (
        request.auth != null
        && request.auth.token.agencyId == agencyId
        && (
          request.auth.token.role == 'admin'
          || request.auth.token.role == 'owner'
          || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
          || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'owner'
        )
      );
    }

    // 1. Agency Logo — Admin / Owner only
    // Allows both agencies/{agencyId}/logo.{ext} AND agencies/{agencyId}/logo/{fileName}
    match /agencies/{agencyId}/{fileName} {
      allow read: if true; // Public — needed for catalogs/website widgets

      allow create, update: if isAgencyAdmin(agencyId)
                            && fileName.matches('logo\\..*')
                            && request.resource.size < 5 * 1024 * 1024
                            && request.resource.contentType.matches('image/.*');

      allow delete: if isAgencyAdmin(agencyId)
                    && fileName.matches('logo\\..*');
    }

    match /agencies/{agencyId}/logo/{fileName} {
      allow read: if true; // Public — needed for catalogs/website widgets

      allow create, update: if isAgencyAdmin(agencyId)
                            && request.resource.size < 5 * 1024 * 1024
                            && request.resource.contentType.matches('image/.*');

      allow delete: if isAgencyAdmin(agencyId);
    }


    // 2. Property Images
    match /agencies/{agencyId}/properties/{propertyId}/images/{fileName} {
      allow read: if true; // Public — needed for catalogs

      // ✅ FIX #5: Verify propertyId actually belongs to this agency via Firestore,
      //            preventing agent X from uploading images under a property owned
      //            by a different agency by guessing a valid propertyId.
      allow create: if request.auth != null
                    && request.auth.token.agencyId == agencyId
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*')
                    && firestore.get(
                         /databases/(default)/documents/agencies/$(agencyId)/properties/$(propertyId)
                       ).data.agencyId == agencyId;

      // Only admins or owners can overwrite or delete property images
      allow update, delete: if request.auth != null
                            && request.auth.token.agencyId == agencyId
                            && (request.auth.token.role == 'admin' || request.auth.token.role == 'owner');
    }


    // 3. Property Videos
    match /agencies/{agencyId}/properties/{propertyId}/videos/{fileName} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.auth.token.agencyId == agencyId
                    && request.resource.size < 200 * 1024 * 1024
                    && request.resource.contentType.matches('video/.*')
                    && firestore.get(
                         /databases/(default)/documents/agencies/$(agencyId)/properties/$(propertyId)
                       ).data.agencyId == agencyId;

      allow update, delete: if request.auth != null
                            && request.auth.token.agencyId == agencyId
                            && (request.auth.token.role == 'admin' || request.auth.token.role == 'owner');
    }

    // 4. Lead Documents / Files
    match /agencies/{agencyId}/leads/{leadId}/{fileName} {
      // Visible only to agents of the same agency
      allow read: if request.auth != null
                  && request.auth.token.agencyId == agencyId;

      // ✅ FIX #3: Added contentType whitelist — previously any file type
      //            (exe, html, script…) up to 15 MB was accepted.
      //            Now restricted to images, PDF, and common Office formats.
      //            The uploader's UID is stored in custom metadata so ownership
      //            can be enforced on update/delete (see FIX #4 below).
      allow create: if request.auth != null
                    && request.auth.token.agencyId == agencyId
                    && request.resource.size < 15 * 1024 * 1024
                    && (
                      request.resource.contentType.matches('image/.*')
                      || request.resource.contentType == 'application/pdf'
                      || request.resource.contentType == 'application/msword'
                      || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
                      || request.resource.contentType == 'application/vnd.ms-excel'
                      || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
                    )
                    // Require uploader to stamp their UID in custom metadata
                    && request.resource.metadata.uploadedBy == request.auth.uid;

      // ✅ FIX #4: Only the original uploader, an admin, or an owner can update/delete a
      //            document. Previously any agent in the agency could overwrite
      //            or delete a colleague's files.
      allow update, delete: if request.auth != null
                            && request.auth.token.agencyId == agencyId
                            && (
                              resource.metadata.uploadedBy == request.auth.uid
                              || request.auth.token.role == 'admin'
                              || request.auth.token.role == 'owner'
                            );
    }

    // ══════════════════════════════════════════════════════════════════════════
    // WHATSAPP BROADCAST ATTACHMENTS
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId}/broadcasts/{fileName} {
      // Visible to public (required for Green API/WAHA to download)
      allow read: if true;

      // Only agents of the agency can upload
      allow create: if request.auth != null
                    && request.auth.token.agencyId == agencyId
                    && request.resource.size < 20 * 1024 * 1024 // 20 MB limit
                    && (
                      request.resource.contentType.matches('image/.*')
                      || request.resource.contentType == 'application/pdf'
                      || request.resource.contentType == 'application/msword'
                      || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
                      || request.resource.contentType == 'application/vnd.ms-excel'
                      || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
                    );

      // Only admins or owners can delete
      allow delete: if request.auth != null
                    && request.auth.token.agencyId == agencyId
                    && (request.auth.token.role == 'admin' || request.auth.token.role == 'owner');
    }

    // ══════════════════════════════════════════════════════════════════════════
    // CONTRACT PDFs
    // Original templates — uploaded by agency admins via ContractEditor.
    // Signed copies — written by the signDeal Cloud Function (Admin SDK bypass).
    // Both are readable publicly so the iframe preview and download links work.
    // ══════════════════════════════════════════════════════════════════════════

    // Contract scans (camera / image uploads) — same permissions as originals
    match /agencies/{agencyId}/contracts/scans/{fileName} {
      allow read: if true;

      allow create: if request.auth != null
                    && (isSuperAdmin() || request.auth.token.agencyId == agencyId)
                    && request.resource.size < 20 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');

      allow update, delete: if false;
    }

    // Original PDF templates uploaded by the agent
    match /agencies/{agencyId}/contracts/originals/{fileName} {
      // Public read: required for iframe preview in editor and signing page,
      // and for the Cloud Function to fetch the bytes via plain fetch().
      allow read: if true;

      // Any agent in the agency can upload template PDFs (20 MB max)
      allow create: if request.auth != null
                    && (isSuperAdmin() || request.auth.token.agencyId == agencyId)
                    && request.resource.size < 20 * 1024 * 1024
                    && request.resource.contentType == 'application/pdf';

      // No client-side update or delete — templates are immutable once linked
      allow update, delete: if false;
    }

    // Signed PDFs produced by the signDeal Cloud Function
    // (Admin SDK writes bypass these rules — we only need read access here)
    match /agencies/{agencyId}/signed_contracts/{dealId}/{fileName} {
      // Public read: needed for the signed PDF download link shown to both parties
      allow read: if true;

      // Writes are Admin SDK only — no client rule needed
      allow write: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // GLOBAL / PUBLIC STORAGE
    // ══════════════════════════════════════════════════════════════════════════
    match /global/properties/{propertyId}/{mediaType}/{fileName} {
      allow read: if true; // Public media is readable by all

      // Only Super Admins can add/update/delete global property media
      allow create, update, delete: if isSuperAdmin()
                                    && request.resource.size < (mediaType == 'videos' ? 200 : 10) * 1024 * 1024
                                    && (
                                      (mediaType == 'images' && request.resource.contentType.matches('image/.*'))
                                      || (mediaType == 'videos' && request.resource.contentType.matches('video/.*'))
                                    );
    }

    // ══════════════════════════════════════════════════════════════════════════
    // CALL RECORDINGS — written by Cloud Functions (Admin SDK), read by agents
    // Auto-deleted after 30 days via GCS Lifecycle Rule (configure in console)
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId}/recordings/{fileName} {
      allow read: if request.auth != null
                  && (
                    isSuperAdmin()
                    || request.auth.token.agencyId == agencyId
                  );
      allow write: if false; // Admin SDK only
    }
  }
}
