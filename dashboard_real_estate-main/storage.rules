rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ══════════════════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ══════════════════════════════════════════════════════════════════════════
    match /{allPaths=**} {
      allow read, write: if false;
    }


    // ══════════════════════════════════════════════════════════════════════════
    // USER PROFILE PICTURES
    // ══════════════════════════════════════════════════════════════════════════
    match /users/{userId}/profile/{fileName} {
      // Profile photos are readable by:
      //  1. The owner themselves
      //  2. ANY authenticated user in the SAME agency (so teammates see each other's avatars)
      // Write/delete is always owner-only.
      allow read: if request.auth != null && (
        request.auth.uid == userId
        || firestore.get(/databases/(default)/documents/users/$(userId)).data.agencyId == request.auth.token.agencyId
      );

      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 5 * 1024 * 1024
                            && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null && request.auth.uid == userId;
    }


    // ══════════════════════════════════════════════════════════════════════════
    // AGENCY STORAGE
    // ✅ FIX #6: Added explicit "/" separator after {agencyId} so that nested
    //            match blocks resolve to the correct full paths in Firebase
    //            Storage (unlike Firestore, Storage path concatenation requires
    //            the leading slash on every child segment).
    // ══════════════════════════════════════════════════════════════════════════

    // 1. Agency Logo — Admin / Owner only
    // Allows both agencies/{agencyId}/logo.{ext} AND agencies/{agencyId}/logo/{fileName}
    match /agencies/{agencyId}/{fileName} {
      allow read: if true; // Public — needed for catalogs/website widgets

      allow create, update: if request.auth != null
                            && request.auth.token.agencyId == agencyId
                            && (request.auth.token.role == 'admin' || request.auth.token.role == 'owner')
                            && fileName.matches('logo\\..*')
                            && request.resource.size < 5 * 1024 * 1024
                            && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null
                    && request.auth.token.agencyId == agencyId
                    && (request.auth.token.role == 'admin' || request.auth.token.role == 'owner')
                    && fileName.matches('logo\\..*');
    }

    match /agencies/{agencyId}/logo/{fileName} {
      allow read: if true; // Public — needed for catalogs/website widgets

      allow create, update: if request.auth != null
                            && request.auth.token.agencyId == agencyId
                            && (request.auth.token.role == 'admin' || request.auth.token.role == 'owner')
                            && request.resource.size < 5 * 1024 * 1024
                            && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null
                    && request.auth.token.agencyId == agencyId
                    && (request.auth.token.role == 'admin' || request.auth.token.role == 'owner');
    }


    // 2. Property Images
    match /agencies/{agencyId}/properties/{propertyId}/images/{fileName} {
      allow read: if true; // Public — needed for catalogs

      // ✅ FIX #5: Verify propertyId actually belongs to this agency via Firestore,
      //            preventing agent X from uploading images under a property owned
      //            by a different agency by guessing a valid propertyId.
      allow create: if request.auth != null
                    && request.auth.token.agencyId == agencyId
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*')
                    && firestore.get(
                         /databases/(default)/documents/properties/$(propertyId)
                       ).data.agencyId == agencyId;

      // Only admins or owners can overwrite or delete property images
      allow update, delete: if request.auth != null
                            && request.auth.token.agencyId == agencyId
                            && (request.auth.token.role == 'admin' || request.auth.token.role == 'owner');
    }


    // 3. Lead Documents / Files
    match /agencies/{agencyId}/leads/{leadId}/{fileName} {
      // Visible only to agents of the same agency
      allow read: if request.auth != null
                  && request.auth.token.agencyId == agencyId;

      // ✅ FIX #3: Added contentType whitelist — previously any file type
      //            (exe, html, script…) up to 15 MB was accepted.
      //            Now restricted to images, PDF, and common Office formats.
      //            The uploader's UID is stored in custom metadata so ownership
      //            can be enforced on update/delete (see FIX #4 below).
      allow create: if request.auth != null
                    && request.auth.token.agencyId == agencyId
                    && request.resource.size < 15 * 1024 * 1024
                    && (
                      request.resource.contentType.matches('image/.*')
                      || request.resource.contentType == 'application/pdf'
                      || request.resource.contentType == 'application/msword'
                      || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
                      || request.resource.contentType == 'application/vnd.ms-excel'
                      || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
                    )
                    // Require uploader to stamp their UID in custom metadata
                    && request.resource.metadata.uploadedBy == request.auth.uid;

      // ✅ FIX #4: Only the original uploader, an admin, or an owner can update/delete a
      //            document. Previously any agent in the agency could overwrite
      //            or delete a colleague's files.
      allow update, delete: if request.auth != null
                            && request.auth.token.agencyId == agencyId
                            && (
                              resource.metadata.uploadedBy == request.auth.uid
                              || request.auth.token.role == 'admin'
                              || request.auth.token.role == 'owner'
                            );
    }

    // ══════════════════════════════════════════════════════════════════════════
    // WHATSAPP BROADCAST ATTACHMENTS
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId}/broadcasts/{fileName} {
      // Visible to public (required for Green API/WAHA to download)
      allow read: if true;

      // Only agents of the agency can upload
      allow create: if request.auth != null
                    && request.auth.token.agencyId == agencyId
                    && request.resource.size < 20 * 1024 * 1024 // 20 MB limit
                    && (
                      request.resource.contentType.matches('image/.*')
                      || request.resource.contentType == 'application/pdf'
                      || request.resource.contentType == 'application/msword'
                      || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
                      || request.resource.contentType == 'application/vnd.ms-excel'
                      || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
                    );

      // Only admins or owners can delete
      allow delete: if request.auth != null
                    && request.auth.token.agencyId == agencyId
                    && (request.auth.token.role == 'admin' || request.auth.token.role == 'owner');
    }
  }
}
