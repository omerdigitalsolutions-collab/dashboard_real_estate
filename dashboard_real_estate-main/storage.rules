rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Allow users to upload their own profile pictures
    match /users/{userId}/profile/{fileName} {
      allow read: if request.auth != null;
      
      allow create, update: if request.auth != null 
                            && request.auth.uid == userId
                            && request.resource.size < 5 * 1024 * 1024 // max 5MB
                            && request.resource.contentType.matches('image/.*');
                            
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // 🔒 SECURED AGENCY STORAGE
    match /agencies/{agencyId} {
      
      // 1. Agency Logo - Only Admins can modify/delete
      match /logo/{fileName} {
        allow read: if true;
        
        allow create, update: if request.auth != null
                              && request.auth.token.agencyId == agencyId
                              && request.auth.token.role == 'admin' // 👈 רק מנהל
                              && request.resource.size < 5 * 1024 * 1024 
                              && request.resource.contentType.matches('image/.*');
                              
        allow delete: if request.auth != null 
                      && request.auth.token.agencyId == agencyId
                      && request.auth.token.role == 'admin'; // 👈 רק מנהל
      }

      // 2. Property Images
      match /properties/{propertyId}/images/{fileName} {
        allow read: if true;
        
        // כל סוכן במשרד יכול להעלות תמונות חדשות לנכס
        allow create: if request.auth != null
                      && request.auth.token.agencyId == agencyId
                      && request.resource.size < 10 * 1024 * 1024 
                      && request.resource.contentType.matches('image/.*');
        
        // מניעת דריסה/מחיקה על ידי סוכנים אחרים - רק מנהל יכול למחוק (או לעדכן/לדרוס)
        allow update, delete: if request.auth != null 
                              && request.auth.token.agencyId == agencyId
                              && request.auth.token.role == 'admin'; // 👈 רק מנהל יכול למחוק
      }

      // 3. Leads Documents / Files
      match /leads/{leadId}/{fileName} {
        // מותר רק לסוכנים במשרד לראות מסמכים של לידים שלהם
        allow read: if request.auth != null && request.auth.token.agencyId == agencyId;
        
        // מותר לכל סוכן להעלות מסמך לליד מקושר למשרד (עד 15 מגה)
        allow create: if request.auth != null
                      && request.auth.token.agencyId == agencyId
                      && request.resource.size < 15 * 1024 * 1024;
                      
        // מחיקה ודריסה - כרגע פתוח לכל סוכן למחוק לעצמו/למשרד.
        // אם תרצה לנעול למנהל בלבד, שנה את זה.
        allow update, delete: if request.auth != null 
                              && request.auth.token.agencyId == agencyId;
      }
    }
  }
}