rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ══════════════════════════════════════════════════════════════════════════

    function isAuthed() {
      return request.auth != null;
    }

    function inAgency(agencyId) {
      return isAuthed() && request.auth.token.agencyId == agencyId;
    }

    function isAdmin() {
      return isAuthed() && request.auth.token.role == 'admin';
    }

    function isAgencyAdmin(agencyId) {
      return inAgency(agencyId) && isAdmin();
    }

    function isSuperAdmin() {
      // Optimiziation: Put this last in boolean chains to avoid document reads when possible
      return isAuthed() && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    function isBootstrapAdmin() {
      return isAuthed() && 
        request.auth.token.email != null && 
        request.auth.token.email_verified == true && (
          request.auth.token.email.lower() == 'omerdigitalsolutions@gmail.com' ||
          request.auth.token.email.lower() == 'omerfm4444@gmail.com' ||
          request.auth.token.email.lower() == 'omerasis4@gmail.com'
        );
    }

    function isNonEmptyString(val) {
      return val is string && val.size() > 0;
    }

    function isPositiveNumber(val) {
      return val is number && val >= 0;
    }

    function agencyIdUnchanged() {
      return request.resource.data.agencyId == resource.data.agencyId;
    }

    /**
     * Returns true if the agency's billing is active (not locked out).
     * An agency is active if:
     *  - No billing field exists yet (new agency during onboarding)
     *  - billing.status is 'active' or 'paid'
     *  - billing.status is 'trialing' AND trial hasn't ended yet
     */
    function isBillingActive(agencyData) {
      // No billing field: allow (onboarding in progress)
      let b = agencyData.get('billing', null);
      if (b == null) return true;

      let status = b.get('status', 'active');

      // Explicitly active/paid
      if (status == 'active' || status == 'paid') return true;

      // Trial: allow only if not expired
      if (status == 'trialing') {
        let trialEnd = b.get('trialEndsAt', null);
        if (trialEnd == null) return true; // No end date = allow
        return request.time < trialEnd;
      }

      // past_due, canceled, or anything else = locked
      return false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ══════════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // AGENCIES
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId} {
      // Read: must be in the agency AND billing must be active (SuperAdmin/Bootstrap bypass billing check)
      allow read: if isAuthed() && (
        isSuperAdmin() || isBootstrapAdmin() ||
        (inAgency(agencyId) && (isBillingActive(resource.data) || isAdmin()))
      );
      allow create: if isBootstrapAdmin();
      
      // ✅ SECURED: Removed 'agencyId' from mutable fields
      allow update: if isAuthed()
          && (isAgencyAdmin(agencyId) || isBootstrapAdmin())
          && (
            isBootstrapAdmin() || 
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'monthlyGoals', 'yearlyGoals', 'settings',
              'agencyName', 'slogan', 'officePhone', 'licenseNumber', 'mainServiceArea', 'specialization',
              'whatsappIntegration', 'updatedAt'
            ])
          );
      allow delete: if isSuperAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // AGENCY AGENTS
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId}/agents/{agentId} {
      allow read: if isAuthed() && (inAgency(agencyId) || isBootstrapAdmin());
      allow create, update, delete: if isAuthed() && (isAgencyAdmin(agencyId) || isBootstrapAdmin());
    }

    // ══════════════════════════════════════════════════════════════════════════
    // AGENCY EXPENSES & INCOMES
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId}/expenses/{expenseId} {
      allow read: if isAuthed() && inAgency(agencyId);
      // ✅ SECURED: Enforced positive amounts, non-empty categories, and valid dates
      allow create, update: if isAuthed() && isAgencyAdmin(agencyId)
          && isPositiveNumber(request.resource.data.amount)
          && isNonEmptyString(request.resource.data.category)
          && request.resource.data.date != null;
      allow delete: if isAuthed() && isAgencyAdmin(agencyId);
    }

    match /agencies/{agencyId}/incomes/{incomeId} {
      allow read: if isAuthed() && inAgency(agencyId);
      // ✅ SECURED: Validations added
      allow create, update: if isAuthed() && isAgencyAdmin(agencyId)
          && isPositiveNumber(request.resource.data.amount)
          && isNonEmptyString(request.resource.data.title)
          && request.resource.data.date != null;
      allow delete: if isAuthed() && isAgencyAdmin(agencyId);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // USERS
    // ══════════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if isAuthed() && (
        request.auth.uid == userId 
        || isSuperAdmin() 
        || isBootstrapAdmin()
        || (resource != null && inAgency(resource.data.agencyId))
        || (resource != null && resource.data.email != null && resource.data.email.lower() == request.auth.token.email.lower())
      );
      
      // ✅ SECURED: Prevented malicious client filters. Agents can only list users in their agency.
      allow list: if isAuthed() && (
        inAgency(resource.data.agencyId) || isSuperAdmin() || isBootstrapAdmin()
      );

      allow create: if isAuthed() && (request.auth.uid == userId || isBootstrapAdmin());
      
      allow update: if isAuthed() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'agencyId']))
        || isAgencyAdmin(resource.data.agencyId) 
        || isSuperAdmin() 
        || isBootstrapAdmin()
      );
      
      allow delete: if isSuperAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // PROPERTIES
    // ══════════════════════════════════════════════════════════════════════════
    match /properties/{propertyId} {
      allow read: if isAuthed() && (inAgency(resource.data.agencyId) || isSuperAdmin());
      allow create: if isAuthed()
          && inAgency(request.resource.data.agencyId)
          && isNonEmptyString(request.resource.data.city)
          && isNonEmptyString(request.resource.data.address)
          && isNonEmptyString(request.resource.data.type)
          && isPositiveNumber(request.resource.data.price);

      allow update: if isAuthed()
          && inAgency(resource.data.agencyId)
          && agencyIdUnchanged()
          && request.resource.data.createdBy == resource.data.createdBy;

      allow delete: if isAuthed() && (
        isAgencyAdmin(resource.data.agencyId) ||
        resource.data.createdBy == request.auth.uid
      );
    }

    // ══════════════════════════════════════════════════════════════════════════
    // LEADS
    // ══════════════════════════════════════════════════════════════════════════
    match /leads/{leadId} {
      allow read: if isAuthed() && (inAgency(resource.data.agencyId) || isSuperAdmin());
      allow create: if isAuthed()
          && inAgency(request.resource.data.agencyId)
          && isNonEmptyString(request.resource.data.name)
          && isNonEmptyString(request.resource.data.phone);

      // ✅ SECURED: Prevent agents from reassigning leads or changing ownership
      allow update: if isAuthed()
          && inAgency(resource.data.agencyId)
          && agencyIdUnchanged()
          && (request.resource.data.createdBy == resource.data.createdBy || isAgencyAdmin(resource.data.agencyId))
          && (request.resource.data.assignedTo == resource.data.assignedTo || isAgencyAdmin(resource.data.agencyId));

      allow delete: if isAuthed() && isAgencyAdmin(resource.data.agencyId);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // LEAD MESSAGES
    // ══════════════════════════════════════════════════════════════════════════
    match /leads/{leadId}/messages/{messageId} {
      // ✅ OPTIMIZED: Grouped to clean up code (Note: still uses a document read)
      function parentAgency() {
        return get(/databases/$(database)/documents/leads/$(leadId)).data.agencyId;
      }
      
      allow read, create: if isAuthed() && inAgency(parentAgency());
      allow update: if isAuthed()
          && inAgency(parentAgency())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);

      allow delete: if isAuthed() && isAgencyAdmin(parentAgency());
    }

    // ══════════════════════════════════════════════════════════════════════════
    // DEALS
    // ══════════════════════════════════════════════════════════════════════════
    match /deals/{dealId} {
      allow read: if isAuthed() && inAgency(resource.data.agencyId);
      allow create: if isAuthed()
          && inAgency(request.resource.data.agencyId)
          && isNonEmptyString(request.resource.data.stage)
          && isPositiveNumber(request.resource.data.projectedCommission);
          
      // ✅ SECURED: Prevent regular agents from marking as Won or inflating commissions
      allow update: if isAuthed()
          && inAgency(resource.data.agencyId)
          && agencyIdUnchanged()
          && (request.resource.data.stage == resource.data.stage || request.resource.data.stage != 'Won' || isAgencyAdmin(resource.data.agencyId))
          && (request.resource.data.projectedCommission == resource.data.projectedCommission || isAgencyAdmin(resource.data.agencyId))
          && (request.resource.data.actualCommission == resource.data.actualCommission || isAgencyAdmin(resource.data.agencyId));

      allow delete: if isAuthed() && isAgencyAdmin(resource.data.agencyId);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // TASKS
    // ══════════════════════════════════════════════════════════════════════════
    match /tasks/{taskId} {
      allow read: if isAuthed() && inAgency(resource.data.agencyId);
      allow create: if isAuthed()
          && inAgency(request.resource.data.agencyId)
          && isNonEmptyString(request.resource.data.title);
      allow update: if isAuthed()
          && inAgency(resource.data.agencyId)
          && agencyIdUnchanged();

      allow delete: if isAuthed() && isAgencyAdmin(resource.data.agencyId);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // ALERTS
    // ══════════════════════════════════════════════════════════════════════════
    match /alerts/{alertId} {
      allow read: if isAuthed() 
          && inAgency(resource.data.agencyId) 
          && resource.data.userId == request.auth.uid;

      allow update: if isAuthed()
          && inAgency(resource.data.agencyId)
          && resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
          && request.resource.data.isRead == true;

      allow create, delete: if false; 
    }

    // ══════════════════════════════════════════════════════════════════════════
    // SHARED CATALOGS
    // ══════════════════════════════════════════════════════════════════════════
    match /shared_catalogs/{catalogId} {
      allow read: if (resource.data.expiresAt > request.time) || (isAuthed() && inAgency(resource.data.agencyId));
      
      // ✅ SECURED: Require auth to prevent bot spam (Requires anonymous auth on frontend)
      allow update: if isAuthed() 
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']) 
          && request.resource.data.viewCount == (resource.data.viewCount + 1);
      
      allow update: if isAuthed()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedPropertyIds'])
          && request.resource.data.likedPropertyIds is list
          && request.resource.data.likedPropertyIds.size() <= 100;

      allow update: if isAuthed() && inAgency(resource.data.agencyId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['propertyIds', 'updatedAt']);
                    
      allow create, delete: if false; 
    }

    // ══════════════════════════════════════════════════════════════════════════
    // PENDING LEADS
    // ══════════════════════════════════════════════════════════════════════════
    match /pending_leads/{leadId} {
      allow read: if isAuthed() && inAgency(resource.data.agencyId);
      allow create: if isAuthed() && inAgency(request.resource.data.agencyId);
      // ✅ SECURED: Only Admins can delete pending leads
      allow delete: if isAuthed() && isAgencyAdmin(resource.data.agencyId);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // PRIVATE & SYSTEM COLLECTIONS
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId}/private_credentials/{document=**} {
      allow read, write: if false;
    }

    match /available_instances/{document=**} {
      allow read, write: if false; 
    }

    match /superAdmins/{userId} {
      allow read:  if isAuthed() && request.auth.uid == userId;
      allow write: if false; 
    }

    // ✅ SECURED: Protected entire admin_settings scope, not just finances
    match /admin_settings/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    match /cities/{cityId} {
      allow read: if isAuthed();
      allow create, update, delete: if isSuperAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // USED PHONES (Anti-abuse trial registry)
    // Read: deny all clients (only Cloud Functions via Admin SDK can read)
    // Write: deny all clients (only Cloud Functions via Admin SDK can write)
    // ══════════════════════════════════════════════════════════════════════════
    match /used_phones/{phone} {
      allow read, write: if false;
    }
  }
}