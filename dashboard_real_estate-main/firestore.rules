rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ══════════════════════════════════════════════════════════════════════════

    function isAuthed() {
      return request.auth != null;
    }

    function inAgency(agencyId) {
      return isAuthed() && request.auth.token.get('agencyId', null) == agencyId;
    }

    function isAdmin() {
      return isAuthed() && request.auth.token.get('role', null) == 'admin';
    }

    function isSuperAdmin() {
      return isAuthed() && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    function isAgencyAdmin(agencyId) {
      return isSuperAdmin() || (inAgency(agencyId) && isAdmin());
    }

    function isNonEmptyString(val) {
      return val is string && val.size() > 0;
    }

    function isPositiveNumber(val) {
      return val is number && val >= 0;
    }

    function agencyIdUnchanged() {
      return request.resource.data.agencyId == resource.data.agencyId;
    }

    /**
     * Returns true if the agency's billing is active (not locked out).
     * An agency is active if:
     *  - No billing field exists yet (new agency during onboarding)
     *  - billing.status is 'active' or 'paid'
     *  - billing.status is 'trialing' AND trial hasn't ended yet
     */
    function isBillingActive(agencyData) {
      return agencyData.get('billing', null) == null ||
             agencyData.billing.get('status', 'active') == 'active' ||
             agencyData.billing.get('status', 'active') == 'paid' ||
             (agencyData.billing.get('status', 'active') == 'trialing' && 
              (agencyData.billing.get('trialEndsAt', null) == null || request.time < agencyData.billing.trialEndsAt));
    }

    /**
     * Checks that the caller's agency billing is active by reading the agency doc.
     * Use this on writes inside top-level collections (leads, properties, etc.)
     * where we can't pass the agency data inline.
     */
    function isBillingActiveForCaller() {
      return isSuperAdmin() || (
        isAuthed() && 
        request.auth.token.get('agencyId', null) != null &&
        isBillingActive(get(/databases/$(database)/documents/agencies/$(request.auth.token.agencyId)).data)
      );
    }

    // ══════════════════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ══════════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // AGENCIES
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId} {
      // Read: must be in the agency AND billing must be active (SuperAdmin/Bootstrap bypass billing check)
      allow read: if isAuthed() && (
        isSuperAdmin() ||
        (inAgency(agencyId) && (isBillingActive(resource.data) || isAdmin()))
      );
      allow create: if isSuperAdmin();

      // Only admins can modify their own agency — agencyId is immutable
      allow update: if isAuthed()
          && (isAgencyAdmin(agencyId) || isSuperAdmin())
          && (
            isSuperAdmin() ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'monthlyGoals', 'yearlyGoals', 'settings',
              'agencyName', 'slogan', 'officePhone', 'licenseNumber', 'mainServiceArea', 'specialization',
              'whatsappIntegration', 'weBotConfig', 'updatedAt'
            ])
          );
      allow delete: if isSuperAdmin();
    }

    match /agencies/{agencyId}/auditLogs/{logId} {
      allow read: if isAuthed() && (inAgency(agencyId) || isSuperAdmin());
      allow create, update, delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // AGENCY AGENTS (subcollection — not to be confused with /users)
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId}/agents/{agentId} {
      allow read: if isAuthed() && (inAgency(agencyId) || isSuperAdmin());
      allow create, update, delete: if isAuthed() && (isAgencyAdmin(agencyId) || isSuperAdmin());
    }

    // ══════════════════════════════════════════════════════════════════════════
    // WHATSAPP PROPERTIES
    // Properties parsed from monitored WhatsApp groups by the AI webhook.
    // Write path is Cloud Functions (Admin SDK) only — clients read only.
    // isExclusive is always false; these are external/B2B draft listings.
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId}/whatsappProperties/{propertyId} {
      // Any authenticated member of the agency can read
      allow read: if isAuthed() && (inAgency(agencyId) || isSuperAdmin());
      // Admins can delete WhatsApp drafts they no longer need
      allow delete: if isAuthed() && (isAgencyAdmin(agencyId) || isSuperAdmin());
      // Updates via updateProperty Cloud Function (Admin SDK bypasses rules).
      // Allow direct updates from agency members but block setting isExclusive=true.
      allow update: if isAuthed()
          && inAgency(agencyId)
          && !('isExclusive' in request.resource.data && request.resource.data.isExclusive == true);
      // Create is Cloud Function (Admin SDK) only — deny from clients
      allow create: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // AGENCY EXPENSES & INCOMES
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId}/expenses/{expenseId} {
      allow read: if isAuthed() && (inAgency(agencyId) || isSuperAdmin());
      allow create: if isAuthed() && (inAgency(agencyId) && (
          isPositiveNumber(request.resource.data.amount) &&
          isNonEmptyString(request.resource.data.category) &&
          request.resource.data.date != null
      ));
      allow update: if isAuthed() && (isSuperAdmin() || (inAgency(agencyId) && (
          isAdmin() || resource.data.createdBy == request.auth.uid
      )));
      allow delete: if isAuthed() && (isSuperAdmin() || (inAgency(agencyId) && (
          isAdmin() || resource.data.createdBy == request.auth.uid
      )));
    }

    match /agencies/{agencyId}/incomes/{incomeId} {
      allow read: if isAuthed() && (inAgency(agencyId) || isSuperAdmin());
      allow create: if isAuthed() && (inAgency(agencyId) && (
          isPositiveNumber(request.resource.data.amount) &&
          isNonEmptyString(request.resource.data.title) &&
          request.resource.data.date != null
      ));
      allow update: if isAuthed() && (isSuperAdmin() || (inAgency(agencyId) && (
          isAdmin() || resource.data.createdBy == request.auth.uid
      )));
      allow delete: if isAuthed() && (isSuperAdmin() || (inAgency(agencyId) && (
          isAdmin() || resource.data.createdBy == request.auth.uid
      )));
    }

    // ══════════════════════════════════════════════════════════════════════════
    // CONTRACTS & DIGITAL SIGNATURES
    // Agents (authenticated) create and manage templates.
    // Anonymous users (clients) can read and fill in field values via direct links.
    // No deletes allowed (immutable archive).
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId}/contracts/{contractId} {
      // Agency members and super admins can read. Anonymous signers (no agencyId claim) also allowed.
      allow read: if isAuthed() && (
        inAgency(agencyId) || isSuperAdmin()
        || request.auth.token.get('agencyId', null) == null
      );
      // Any authenticated agent in the agency can create
      allow create: if (inAgency(agencyId) || isSuperAdmin()) && isBillingActiveForCaller();

      // Agency members or anonymous signers can update, but not after contract is completed
      allow update: if isAuthed()
        && resource.data.status != 'completed'
        && (inAgency(agencyId) || isSuperAdmin() || request.auth.token.get('agencyId', null) == null);

      // Deletes are prohibited — contracts are archived forever
      allow delete: if false;
    }

    // System-wide contract templates — readable by any authenticated user, writable by super admins only
    match /systemTemplates/{templateId} {
      allow read: if isAuthed();
      allow write: if isSuperAdmin();
    }

    match /agencies/{agencyId}/contractTemplates/{templateId} {
      // Agency members + anonymous signers (no agencyId claim) can read (needed to render signing page)
      allow read: if isAuthed() && (
        inAgency(agencyId) || isSuperAdmin()
        || request.auth.token.get('agencyId', null) == null
      );
      // Write: agency members only (with active billing)
      allow create, update: if isAuthed() && (inAgency(agencyId) || isSuperAdmin()) && isBillingActiveForCaller();
      allow delete: if isAuthed() && (isAgencyAdmin(agencyId) || isSuperAdmin());
    }

    match /agencies/{agencyId}/contractInstances/{instanceId} {
      // Agency members + anonymous signers (no agencyId claim) can read
      allow read: if isAuthed() && (
        inAgency(agencyId) || isSuperAdmin()
        || request.auth.token.get('agencyId', null) == null
      );
      // Any authenticated agent in the agency can create instances
      allow create: if isAuthed() && (inAgency(agencyId) || isSuperAdmin()) && isBillingActiveForCaller();

      // Agency members or anonymous signers can update field values, blocked after signing
      allow update: if isAuthed()
          && resource.data.status != 'completed'
          && resource.data.status != 'signed'
          && (inAgency(agencyId) || isSuperAdmin() || request.auth.token.get('agencyId', null) == null);

      // Only agency admins or the creator can delete drafts
      allow delete: if isAuthed() && (isAgencyAdmin(agencyId) || isSuperAdmin() || resource.data.createdBy == request.auth.uid);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // USERS
    // ══════════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Read own doc, or any doc in same agency, or super/bootstrap admins
      allow read: if isAuthed() && (
        request.auth.uid == userId
        || isSuperAdmin()
        || (resource != null && inAgency(resource.data.agencyId))
        || (resource != null && resource.data.email != null && request.auth.token.get('email', '') != '' && resource.data.email.lower() == request.auth.token.email.lower())
      );

      // List: agents can only see their own agency
      allow list: if isAuthed() && (
        inAgency(resource.data.agencyId) || isSuperAdmin()
      );

      // Allow creating own user doc on signup, or by super admin
      allow create: if isAuthed() && (request.auth.uid == userId || isSuperAdmin());

      // Regular users can only update their own profile fields (not role or agencyId)
      allow update: if isAuthed() && (
        // Normal profile edits (name, phone, avatar etc.) — cannot change role or agency
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'agencyId']))
        // ── Invite Claim ──────────────────────────────────────────────────────
        // Any authenticated user may claim an *unclaimed* stub (uid == null)
        // by writing only their own UID into the uid field. This powers the
        // invite-link join flow without requiring a Cloud Function deployment.
        || (resource.data.uid == null
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid']))
        // ── Admin / Super-admin overrides ─────────────────────────────────────
        || isAgencyAdmin(resource.data.agencyId)
        || isSuperAdmin()
      );

      allow delete: if isSuperAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // PROPERTIES (subcollection under agency)
    // Path: agencies/{agencyId}/properties/{propId}
    // agencyId is enforced by path — no need to check the field inside the doc.
    // ══════════════════════════════════════════════════════════════════════════
    match /agencies/{agencyId}/properties/{propId} {
      // Public properties or collaborative properties are readable by any authenticated user
      allow read: if resource.data.visibility == 'public'
          || resource.data.collaborationStatus == 'collaborative'
          || (isAuthed() && (inAgency(agencyId) || isSuperAdmin()));

      // Direct client creates allowed for agency members (e.g. batch import).
      allow create: if isAuthed()
          && (inAgency(agencyId) || isSuperAdmin())
          && isBillingActiveForCaller();

      // Admins can update any property. Agents can only update their own.
      allow update: if isAuthed()
          && (inAgency(agencyId) || isSuperAdmin())
          && isBillingActiveForCaller()
          && (isAdmin() || isSuperAdmin() || resource.data.management.get('assignedAgentId', null) == request.auth.uid);

      // Admins can delete any property. Agents can only delete their own.
      allow delete: if isAuthed()
          && inAgency(agencyId)
          && (isAdmin() || resource.data.management.get('assignedAgentId', null) == request.auth.uid);
    }

    // Support collectionGroup queries for properties
    match /{path=**}/properties/{propId} {
      allow read: if resource.data.collaborationStatus == 'collaborative'
          || resource.data.visibility == 'public'
          || (isAuthed() && (inAgency(resource.data.agencyId) || isSuperAdmin()));
    }

    // ══════════════════════════════════════════════════════════════════════════
    // LEADS
    // Same rationale: create/delete go through Cloud Functions.
    // ══════════════════════════════════════════════════════════════════════════
    match /leads/{leadId} {
      allow read: if isAuthed() && (
        isSuperAdmin() ||
        resource.data.collaborationStatus == 'collaborative' ||
        (inAgency(resource.data.agencyId) && (isAdmin() || resource.data.assignedAgentId == request.auth.uid))
      );

      // Support collectionGroup queries for leads (even though leads are top-level, it's good practice)
      allow list: if isAuthed() && (
        isSuperAdmin() ||
        resource.data.collaborationStatus == 'collaborative' ||
        inAgency(resource.data.agencyId)
      );

      // Direct client creates allowed for authenticated agency members (e.g. batch import)
      // if they set the correct agencyId and billing is active.
      allow create: if isAuthed()
          && (inAgency(request.resource.data.agencyId) || isSuperAdmin())
          && isBillingActiveForCaller();

      // Updates: admins can update any lead. Agents can only update leads assigned to them.
      allow update: if isAuthed()
          && (inAgency(resource.data.agencyId) || isSuperAdmin())
          && (agencyIdUnchanged() || isSuperAdmin())
          && isBillingActiveForCaller()
          && (isAdmin() || isSuperAdmin() || resource.data.assignedAgentId == request.auth.uid);

      // Deletes: admins can delete any lead. Agents can only delete leads assigned to them.
      allow delete: if isAuthed()
          && inAgency(resource.data.agencyId)
          && (isAdmin() || resource.data.assignedAgentId == request.auth.uid);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // COLLABORATIONS (Marketplace Requests)
    // ══════════════════════════════════════════════════════════════════════════
    match /collaborations/{requestId} {
      allow read: if isAuthed() && (
        request.auth.token.get('agencyId', null) == resource.data.fromAgencyId ||
        request.auth.token.get('agencyId', null) == resource.data.toAgencyId ||
        isSuperAdmin()
      );
      allow create: if isAuthed() && (
        request.auth.token.get('agencyId', null) == request.resource.data.fromAgencyId ||
        isSuperAdmin()
      );
      allow update: if isAuthed() && (
        request.auth.token.get('agencyId', null) == resource.data.fromAgencyId ||
        request.auth.token.get('agencyId', null) == resource.data.toAgencyId ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // LEAD MESSAGES
    // ══════════════════════════════════════════════════════════════════════════
    match /leads/{leadId}/messages/{messageId} {
      allow read, create: if isAuthed() && inAgency(get(/databases/$(database)/documents/leads/$(leadId)).data.agencyId);
      allow update: if isAuthed()
          && inAgency(get(/databases/$(database)/documents/leads/$(leadId)).data.agencyId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);

      allow delete: if isAuthed() && isAgencyAdmin(get(/databases/$(database)/documents/leads/$(leadId)).data.agencyId);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // DEALS
    // ══════════════════════════════════════════════════════════════════════════
    match /deals/{dealId} {
      allow read: if isAuthed() && (
        isSuperAdmin() ||
        (inAgency(resource.data.agencyId) && (isAdmin() || resource.data.createdBy == request.auth.uid || resource.data.agentId == request.auth.uid))
      );
      allow create: if isAuthed()
          && (inAgency(request.resource.data.agencyId) || isSuperAdmin())
          && isNonEmptyString(request.resource.data.stage)
          && isPositiveNumber(request.resource.data.projectedCommission)
          && isBillingActiveForCaller();

      // Any agency member can update deals (stage changes, notes, etc).
      // Only admins can change commission amounts.
      // Marking 'won' (actualCommission) is also admin-only.
      allow update: if isAuthed()
          && (inAgency(resource.data.agencyId) || isSuperAdmin())
          && (agencyIdUnchanged() || isSuperAdmin())
          && isBillingActiveForCaller()
          && (request.resource.data.projectedCommission == resource.data.projectedCommission || isAgencyAdmin(resource.data.agencyId) || isSuperAdmin())
          && (request.resource.data.actualCommission == resource.data.actualCommission || isAgencyAdmin(resource.data.agencyId) || isSuperAdmin());

      // Admins can delete any deal. Agents can only delete deals they created.
      allow delete: if isAuthed()
          && inAgency(resource.data.agencyId)
          && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // TASKS
    // ══════════════════════════════════════════════════════════════════════════
    match /tasks/{taskId} {
      // Agents can read their own tasks or tasks assigned to them.
      // Admins can read all tasks in their agency.
      allow read: if isAuthed() && inAgency(resource.data.agencyId)
          && (isAdmin() || resource.data.createdBy == request.auth.uid || resource.data.assignedToAgentId == request.auth.uid);

      allow create: if isAuthed()
          && (inAgency(request.resource.data.agencyId) || isSuperAdmin())
          && isNonEmptyString(request.resource.data.title);

      // Agents can update tasks they created OR tasks assigned to them (e.g. task completion).
      allow update: if isAuthed()
          && (inAgency(resource.data.agencyId) || isSuperAdmin())
          && (agencyIdUnchanged() || isSuperAdmin())
          && (isAdmin() || isSuperAdmin() || resource.data.createdBy == request.auth.uid || resource.data.assignedToAgentId == request.auth.uid);

      // Agents can delete tasks they created. Admins can delete any task.
      allow delete: if isAuthed()
          && inAgency(resource.data.agencyId)
          && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // ALERTS
    // Alerts are written by Cloud Functions (triggers) — deny both create/delete
    // from clients. Only allow reading and marking as read.
    // ══════════════════════════════════════════════════════════════════════════
    match /alerts/{alertId} {
      // Agents can read their own personal alerts or agency-wide broadcasts.
      allow read: if isAuthed()
          && inAgency(resource.data.agencyId)
          && (resource.data.targetAgentId == request.auth.uid || resource.data.targetAgentId == 'all');

      // Agents can only mark their own alerts as read
      allow update: if isAuthed()
          && inAgency(resource.data.agencyId)
          && (resource.data.targetAgentId == request.auth.uid || resource.data.targetAgentId == 'all')
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
          && request.resource.data.isRead == true;

      // Alerts can be created by authenticated agency members (for task assignment notifications from the client).
      // Agency admins can also create alerts.
      allow create: if isAuthed() && (inAgency(request.resource.data.agencyId) || isSuperAdmin());

      // Delete: admin only
      allow delete: if isAuthed() && isAgencyAdmin(resource.data.agencyId);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // SHARED CATALOGS
    // ══════════════════════════════════════════════════════════════════════════
    match /shared_catalogs/{catalogId} {
      // Allow reading by anyone who is signed in — including anonymous users who arrive via a shared link.
      // The client and/or Cloud Function handles expiry checks, not this rule.
      // This is required so that the "link expired" page can be shown gracefully.
      allow read: if isAuthed();

      // Allow incrementing viewCount (public link visitors might not be authenticated)
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
          && request.resource.data.viewCount == (resource.data.viewCount + 1);

      // Allow updating liked properties list (authenticated users only — anonymous Firebase auth suffices)
      allow update: if request.auth != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedPropertyIds'])
          && request.resource.data.likedPropertyIds is list
          && request.resource.data.likedPropertyIds.size() <= 100;

      // Agency admins can update the property list
      allow update: if isAuthed() && inAgency(resource.data.agencyId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['propertyIds', 'updatedAt']);

      // Create/delete via Cloud Functions only
      allow create, delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // PENDING LEADS
    // ══════════════════════════════════════════════════════════════════════════
    match /pending_leads/{leadId} {
      allow read: if isAuthed() && inAgency(resource.data.agencyId);
      allow create: if isAuthed() && inAgency(request.resource.data.agencyId);
      // Only admins can approve/delete pending leads
      allow delete: if isAuthed() && isAgencyAdmin(resource.data.agencyId);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // PRIVATE & SYSTEM COLLECTIONS — Server/Admin SDK only
    // ══════════════════════════════════════════════════════════════════════════

    // Green API credentials and other secrets — never readable by clients
    match /agencies/{agencyId}/private_credentials/{document=**} {
      allow read, write: if false;
    }

    match /available_instances/{document=**} {
      allow read, write: if false;
    }

    // Super Admin registry — users can only verify their own membership
    match /superAdmins/{userId} {
      allow read:  if isAuthed() && request.auth.uid == userId;
      allow write: if false;
    }

    // Admin financial settings — only super admins
    match /admin_settings/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // City/area reference data — public read, admin write
    match /cities/{cityId} {
      allow read: if isAuthed();
      allow create, update, delete: if false;
    }

    match /userTokens/{document=**} {
      allow read, write: if false;
    }

    match /cities/{cityId}/properties/{propertyId} {
      allow read: if isAuthed();
      allow create, update, delete: if false;
    }

    // Anti-abuse trial phone registry — Cloud Functions (Admin SDK) only
    match /used_phones/{phone} {
      allow read, write: if false;
    }
    // Server-managed active trials collection
    match /activeTrials/{document=**} {
      allow read, write: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // B2C SEARCH ALERTS — write-only for anonymous visitors
    // ══════════════════════════════════════════════════════════════════════════
    match /searchAlerts/{alertId} {
      allow create: if request.resource.data.phone is string
          && request.resource.data.phone.size() > 5
          && request.resource.data.active == true;
      allow read, update, delete: if isSuperAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // PUBLIC SUBSCRIPTION REQUESTS
    // ══════════════════════════════════════════════════════════════════════════
    match /subscription_requests/{requestId} {
      // Anyone can submit a lead, even unauthenticated visitors
      allow create: if true;
      // Reading/updating restricted to Server/SuperAdmin
      allow read, update, delete: if isSuperAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // RATE LIMITS — Server (Admin SDK) only — never readable or writable by clients
    // ══════════════════════════════════════════════════════════════════════════
    match /_rate_limits/{document=**} {
      allow read, write: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // BOT SECURITY COLLECTIONS — Admin SDK (Cloud Functions) only
    // ══════════════════════════════════════════════════════════════════════════
    match /whatsapp_sessions/{doc} { allow read, write: if false; }
    match /whatsapp_blocklist/{doc} { allow read, write: if false; }
    match /whatsapp_suspicious/{doc} { allow read, write: if false; }
    match /whatsapp_audit_log/{doc} { allow read, write: if false; }
    match /processed_messages/{doc} { allow read, write: if false; }

    // ══════════════════════════════════════════════════════════════════════════
    // COLLABORATIONS
    // ══════════════════════════════════════════════════════════════════════════
    match /collaborations/{collabId} {
      allow read: if isAuthed() && (
        inAgency(resource.data.propertyAgencyId) || 
        inAgency(resource.data.requestingAgencyId) || 
        isSuperAdmin()
      );
      
      allow create: if isAuthed() && (
        inAgency(request.resource.data.requestingAgencyId) || 
        isSuperAdmin()
      ) && isBillingActiveForCaller();

      allow update: if isAuthed() && (
        inAgency(resource.data.propertyAgencyId) || 
        inAgency(resource.data.requestingAgencyId) || 
        isSuperAdmin()
      );

      allow delete: if isSuperAdmin();
    }
  }
}